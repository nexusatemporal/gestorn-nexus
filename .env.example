# ============================================================================
# GESTOR NEXUS - Variáveis de Ambiente
# ============================================================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores
# 3. NUNCA commite o arquivo .env
#
# ============================================================================

# ============================================================================
# BANCO DE DADOS
# ============================================================================

# Desenvolvimento local
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestor_nexus"

# Produção (Portainer) - usar service name
# DATABASE_URL="postgresql://gestor:SENHA_SEGURA@postgres:5432/gestor_nexus"

# Postgres (apenas produção)
POSTGRES_USER=gestor
POSTGRES_PASSWORD=ALTERE_ESTA_SENHA
POSTGRES_DB=gestor_nexus

# ============================================================================
# CLERK (AUTENTICAÇÃO)
# ============================================================================
# Obter em: https://dashboard.clerk.com → API Keys

# Backend (sk_ = secret key)
CLERK_SECRET_KEY=sk_test_XXXXX

# Frontend (pk_ = publishable key)
CLERK_PUBLISHABLE_KEY=pk_test_XXXXX
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXX

# Webhooks (whsec_ = webhook secret)
CLERK_WEBHOOK_SECRET=whsec_XXXXX

# ============================================================================
# PAGAMENTOS - ABACATEPAY (PIX)
# ============================================================================
# Obter em: https://abacatepay.com/dashboard

ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# ============================================================================
# PAGAMENTOS - ASAAS (CARTÃO/BOLETO)
# ============================================================================
# Obter em: https://www.asaas.com/integracoes

ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
# Ambiente: sandbox ou production
ASAAS_ENV=sandbox

# ============================================================================
# INTELIGÊNCIA ARTIFICIAL
# ============================================================================

# Groq - Processamento batch
# Obter em: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini - Chat real-time
# Obter em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter (alternativa)
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ============================================================================
# EMAIL (SMTP)
# ============================================================================

SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Gestor Nexus <noreply@nexusatemporal.com.br>"

# ============================================================================
# GOOGLE CALENDAR (OAUTH2 + BIDIRECTIONAL SYNC)
# ============================================================================
# Obter em: https://console.cloud.google.com → APIs & Services → Credentials

# OAuth2 Credentials (copiar do Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI (deve ser EXATAMENTE igual ao configurado no Google Cloud)
# Desenvolvimento:
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/calendar/google/callback

# Produção:
GOOGLE_REDIRECT_URI=https://gestornx.nexusatemporal.com/api/v1/calendar/google/callback

# Chave de criptografia para tokens do Google (gerar com: openssl rand -hex 32)
# IMPORTANTE: Gerar chave aleatória de 32 bytes em hexadecimal
ENCRYPTION_KEY=

# ============================================================================
# APLICAÇÃO
# ============================================================================

NODE_ENV=development
PORT=3001

# URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api/v1

# Produção
# API_URL=https://apigestor.nexusatemporal.com
# WEB_URL=https://gestornx.nexusatemporal.com
# VITE_API_URL=https://apigestor.nexusatemporal.com/api/v1

# ============================================================================
# REDIS (OPCIONAL)
# ============================================================================

REDIS_URL=redis://localhost:6379
# Produção: redis://redis:6379

# ============================================================================
# LOGS E MONITORAMENTO
# ============================================================================

LOG_LEVEL=debug
# Produção: info

# Sentry (opcional)
SENTRY_DSN=

# ============================================================================
# SEGURANÇA
# ============================================================================

# Domínios permitidos no CORS (separados por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Produção
# CORS_ORIGINS=https://gestornx.nexusatemporal.com,https://www.gestornx.nexusatemporal.com

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================================================
# BACKUP - IDRIVE E2 (S3-COMPATIBLE)
# ============================================================================
# Obter em: https://www.idrive.com/e2/

# Credenciais IDrive e2
IDRIVE_ACCESS_KEY_ID=D6ePFHwXGk9Kf1f6mlio
IDRIVE_SECRET_ACCESS_KEY=s2o2eIzSnRYFtlCusAL5zl2JLaD8JmT05FSnVHJs

# Configuração S3
IDRIVE_ENDPOINT=https://o0m5.va.idrivee2-26.com
IDRIVE_REGION=us-east-1
IDRIVE_BUCKET=gestornexus

# Retenção (dias)
BACKUP_RETENTION_DAYS=30

# Executar backup ao iniciar container
RUN_BACKUP_ON_START=false

# Manter backup local após upload
KEEP_LOCAL_BACKUP=false

# ============================================================================
# ONE NEXUS INTEGRATION
# ============================================================================

# URL base da API do One Nexus
ONE_NEXUS_API_URL=https://apione.nexusatemporal.com.br/api

# API Key para autenticação (header X-API-Key)
ONE_NEXUS_API_KEY=gnx_7e78d362e353f0221ca261352069d9e1c1fbe024857af1e60167c7c994970193

# ============================================================================
# FIM
# ============================================================================
