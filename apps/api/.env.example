# ======== APLICAÇÃO ========
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ======== BANCO DE DADOS ========
DATABASE_URL="postgresql://gestor:senha_dev@localhost:5432/gestor_nexus?schema=public"

# ======== CLERK (AUTENTICAÇÃO) ========
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# ======== PAGAMENTOS ========
# AbacatePay (PIX)
ABACATEPAY_API_KEY=xxxxx
ABACATEPAY_WEBHOOK_SECRET=xxxxx

# Asaas (Cartão/Boleto)
ASAAS_API_KEY=xxxxx
ASAAS_WEBHOOK_TOKEN=xxxxx

# ======== INTELIGÊNCIA ARTIFICIAL ========
# Nexus Sales AI - Multi-Provider System
GROQ_API_KEY=xxxxx          # Groq (llama-3.3-70b) - Ultra-rápido para chat e briefings
GEMINI_API_KEY=xxxxx        # Gemini 2.0 Flash - Análises longas e DISC
OPENAI_API_KEY=xxxxx        # OpenAI (gpt-4o) - Criatividade e roleplay

# OpenRouter (Alternativa - Fallback)
OPENROUTER_API_KEY=xxxxx

# ======== SMTP (Zoho) ========
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=xxxxx
SMTP_PASS=xxxxx
SMTP_FROM=noreply@nexusatemporal.com

# ======== URLS ========
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ======== CORS ========
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ======== LOGS ========
LOG_LEVEL=debug

# ======== JOBS E CRON ========
ENABLE_CRON_JOBS=false
AI_BATCH_CRON=0 19 * * *

# ======== SLACK (OPCIONAL) ========
# Webhook URL para alertas críticos (PAYMENT_OVERDUE, AI_CHURN_ALERT, SYSTEM_ALERT)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx/xxxxx/xxxxx

